{
  "info": {
    "name": "EasyMype API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"empresaNombre\": \"Mi Empresa Test\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.collectionVariables.set(\"token\", res.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Crear producto",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/products", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Producto de prueba\",\n  \"descripcion\": \"Descripción del producto\",\n  \"sku\": \"SKU-001\",\n  \"stockActual\": 100,\n  \"stockMinimo\": 10,\n  \"precioVenta\": 25.99,\n  \"costo\": 15.00,\n  \"categoriaIds\": []\n}"
            }
          }
        },
        {
          "name": "Listar productos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/products", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products"] }
          }
        },
        {
          "name": "Obtener producto por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/products/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "1"] }
          }
        },
        {
          "name": "Actualizar producto",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/products/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Producto actualizado\",\n  \"descripcion\": \"Nueva descripción\",\n  \"sku\": \"SKU-001\",\n  \"stockActual\": 80,\n  \"stockMinimo\": 10,\n  \"precioVenta\": 29.99,\n  \"costo\": 18.00,\n  \"categoriaIds\": []\n}"
            }
          }
        },
        {
          "name": "Eliminar producto",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/products/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "1"] }
          }
        },
        {
          "name": "Productos con stock bajo",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/products/low-stock", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "low-stock"] }
          }
        },
        {
          "name": "Productos sin stock",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/products/out-of-stock", "host": ["{{baseUrl}}"], "path": ["api", "v1", "products", "out-of-stock"] }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Crear categoría",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/categories", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Electrónica\"\n}"
            }
          }
        },
        {
          "name": "Listar categorías",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/categories", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories"] }
          }
        },
        {
          "name": "Actualizar categoría",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/categories/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Tecnología\"\n}"
            }
          }
        },
        {
          "name": "Eliminar categoría",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/categories/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "categories", "1"] }
          }
        }
      ]
    },
    {
      "name": "Sales",
      "item": [
        {
          "name": "Registrar venta",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/sales", "host": ["{{baseUrl}}"], "path": ["api", "v1", "sales"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    { \"productoId\": 1, \"cantidad\": 2 }\n  ]\n}"
            }
          }
        },
        {
          "name": "Listar ventas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/sales", "host": ["{{baseUrl}}"], "path": ["api", "v1", "sales"] }
          }
        },
        {
          "name": "Obtener venta por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/sales/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "sales", "1"] }
          }
        }
      ]
    },
    {
      "name": "Alerts",
      "item": [
        {
          "name": "Listar alertas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/alerts", "host": ["{{baseUrl}}"], "path": ["api", "v1", "alerts"] }
          }
        },
        {
          "name": "Marcar alerta como leída",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/alerts/1/read", "host": ["{{baseUrl}}"], "path": ["api", "v1", "alerts", "1", "read"] }
          }
        },
        {
          "name": "Eliminar alerta",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/alerts/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "alerts", "1"] }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Resumen del dashboard",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/dashboard/summary", "host": ["{{baseUrl}}"], "path": ["api", "v1", "dashboard", "summary"] }
          }
        }
      ]
    },
    {
      "name": "Tables & Cells",
      "item": [
        {
          "name": "Crear tabla",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/tables", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tables"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Tabla de inventario\",\n  \"proyectoId\": 1\n}"
            }
          }
        },
        {
          "name": "Listar tablas",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/tables", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tables"] }
          }
        },
        {
          "name": "Obtener tabla por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/api/v1/tables/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tables", "1"] }
          }
        },
        {
          "name": "Agregar columna a tabla",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/tables/1/columns", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tables", "1", "columns"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Columna 1\",\n  \"orden\": 1\n}"
            }
          }
        },
        {
          "name": "Agregar fila a tabla",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/tables/1/rows", "host": ["{{baseUrl}}"], "path": ["api", "v1", "tables", "1", "rows"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orden\": 1,\n  \"productoId\": 1\n}"
            }
          }
        },
        {
          "name": "Actualizar celda",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/v1/cells/1", "host": ["{{baseUrl}}"], "path": ["api", "v1", "cells", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"valorTexto\": \"nuevo valor\"\n}"
            }
          }
        }
      ]
    }
  ]
}
